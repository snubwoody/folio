{
    "name": "folio",
    "type": "module",
    "private": true,
    "scripts": {
        "lint": "eslint . --max-warnings 0 && stylelint **/*.{css,svelte} --max-warnings 0",
        "dev:desktop": "cargo tauri dev",
        "dev:web": "pnpm -F web dev",
        "db:create": "cargo sqlx database create",
        "db:migrate": "cargo sqlx migrate run --source crates/folio-desktop/migrations",
        "db:setup": "cargo sqlx database drop -y && pnpm db:create && pnpm db:migrate",
        "lint:fix": "eslint . --max-warnings 0 --fix && stylelint **/*.{css,svelte} --max-warnings 0 --fix",
        "lint:styles": "stylelint **/*.{css,svelte} --max-warnings 0"
    },
    "dependencies": {
        "@astrojs/node": "^9.5.5",
        "@astrojs/sitemap": "^3.7.2",
        "@astrojs/vercel": "^8.2.11",
        "@lucide/astro": "^0.553.0",
        "@lucide/svelte": "^1.0.0",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-updater": "^2.10.0",
        "astro": "^5.18.1",
        "phosphor-astro": "^2.1.0",
        "sharp": "^0.34.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@eslint/js": "^9.39.4",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^5.1.1",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^24.12.0",
        "@vitest/browser": "^3.2.4",
        "@vitest/coverage-v8": "^3.2.4",
        "bits-ui": "^2.16.4",
        "eslint": "^9.39.4",
        "eslint-plugin-astro": "^1.6.0",
        "eslint-plugin-svelte": "^3.16.0",
        "globals": "^16.5.0",
        "jsdom": "^27.4.0",
        "melt": "^0.41.0",
        "phosphor-icons-svelte": "^2.1.0",
        "playwright": "^1.58.2",
        "postcss-html": "^1.8.1",
        "stylelint": "^16.26.1",
        "stylelint-config-recommended-scss": "^16.0.2",
        "stylelint-config-standard": "^39.0.1",
        "svelte": "^5.55.1",
        "svelte-check": "^4.4.5",
        "svelte-eslint-parser": "^1.6.0",
        "tailwindcss": "^4.2.2",
